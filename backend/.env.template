# =============================================================
#  Backend API — Environment Variable Template
# =============================================================
# Copy this file to ".env" and fill in real values.
# NEVER commit ".env" to version control.
#
# On an EC2 instance you can either:
#   (a) export these as real shell env vars in your systemd unit, OR
#   (b) keep a .env file in the project directory (less secure)
# =============================================================

# ── PostgreSQL / RDS ──────────────────────────────────────────────────────────
# The endpoint shown in RDS Console → Connectivity & security
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=appdb
DB_USER=postgres
DB_PASSWORD=your_strong_password_here

# ── AWS Region ────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# ── S3 ────────────────────────────────────────────────────────────────────────
# The bucket must already exist and the IAM role/user must have s3:PutObject
S3_BUCKET_NAME=your-s3-bucket-name

# ── SNS ───────────────────────────────────────────────────────────────────────
# Copy the Topic ARN from SNS Console → Topics
# e.g. arn:aws:sns:us-east-1:123456789012:app-notifications
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:ACCOUNT_ID:your-topic-name

# ── AWS Credentials ───────────────────────────────────────────────────────────
# Leave BLANK if the EC2 instance has an IAM Role attached (recommended).
# Only set these for local development or if NOT using IAM Roles.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
