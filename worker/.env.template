# =============================================================
#  Background Worker — Environment Variable Template
# =============================================================
# Uses the SAME database and SNS settings as the backend.
# Copy to ".env" and fill in real values.
# =============================================================

# ── PostgreSQL / RDS ──────────────────────────────────────────────────────────
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=appdb
DB_USER=postgres
DB_PASSWORD=your_strong_password_here

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:ACCOUNT_ID:your-topic-name

# ── Worker tuning ─────────────────────────────────────────────────────────────
# How often the worker checks for new pending items (in seconds)
POLL_INTERVAL_SECONDS=30

# ── AWS Credentials (leave blank when using EC2 IAM Role) ────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
