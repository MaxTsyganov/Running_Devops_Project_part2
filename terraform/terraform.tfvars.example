# A globally unique name for the S3 bucket (no spaces or uppercase letters)
bucket_name = "instructor-test-bucket-12345"

# Your email address to receive SNS deployment alerts
my_email    = "instructor@example.com"

# The master password for the RDS PostgreSQL database (Must be at least 8 characters)
db_password = "REPLACE_WITH_STRONG_PASSWORD"